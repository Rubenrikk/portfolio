/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  # HSTS alleen effectief op custom domeinen met HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # HTML: niet cachen of heel kort
  Cache-Control: no-cache, no-store, must-revalidate

# Astro gebuilde assets (content-hashed)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Overige statische assets (in public/assets of elders)
/*.(css|js|mjs|cjs|map|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf|eot)
  Cache-Control: public, max-age=31536000, immutable

# Favicon afzonderlijk (sterk gecachet)
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# Root en directory-indexen kort cachen
/
  Cache-Control: no-cache, no-store, must-revalidate

/*/
  Cache-Control: no-cache, no-store, must-revalidate


