---
import Boton from "../components/atoms/Boton.astro";
import Layout from "../layouts/Layout.astro";
import Header from "../components/header/Header.astro";
import { menu404 } from "../components/data/menuData.js";

---

<Layout title="Pagina niet gevonden">
        <Header origin={menu404} />
        <section class="min-h-[100dvh] flex items-center justify-center px-6 py-16">
                <div class="max-w-2xl w-full text-center space-y-6">
                        <div class="text-6xl">🧭</div>
                        <h1 class="text-3xl md:text-4xl font-semibold">Pagina niet gevonden</h1>
                        <p class="opacity-80">
                                Oeps, deze pagina bestaat niet (meer) of de link klopt niet.
                                Controleer de URL of ga terug naar de startpagina.
                        </p>
                        <ul class="text-left mx-auto inline-block list-disc list-inside space-y-1 opacity-80">
                                <li>De pagina is verplaatst of verwijderd</li>
                                <li>Er staat een typefout in de URL</li>
                                <li>De link is verouderd</li>
                        </ul>
                        <div class="pt-2 flex justify-center">
                                <Boton texto="Terug naar home" href="/"/>
                        </div>
                </div>
        </section>
</Layout>